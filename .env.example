port=4000
# Comma-separated allowed origins for CORS
# Add your LAN origin when testing from another device (example below)
frontend_origin=http://localhost:3000,http://192.168.0.49:3000

# Web Push (VAPID) keys
# Required for browser push notifications. Keep PRIVATE key secret.
VAPID_SUBJECT=mailto:admin@happyears.local
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY

type=service_account
project_id=YOUR_FIREBASE_PROJECT_ID
private_key_id=YOUR_PRIVATE_KEY_ID
private_key="YOUR_PRIVATE_KEY_WITH_ESCAPED_NEWLINES"
client_email=YOUR_CLIENT_EMAIL
client_id=YOUR_CLIENT_ID
auth_uri=https://accounts.google.com/o/oauth2/auth
token_uri=https://oauth2.googleapis.com/token
auth_provider_x509_cert_url=https://www.googleapis.com/oauth2/v1/certs
client_x509_cert_url=YOUR_CLIENT_CERT_URL
universe_domain=googleapis.com

default_bucket=YOUR_STORAGE_BUCKET

# Admin panel permission-update password
ADMIN_ROLE_UPDATE_PASSWORD=change-this-admin-password

# Database backup script password
BACKUP_SCRIPT_PASSWORD=change-this-backup-password
